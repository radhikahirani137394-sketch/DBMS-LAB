\ulnone\b0\caps . 1. Create the following table named table as CUSTOMER with proper normalization.\par
ANSWER- CREATE TABLE CUSTOMER (    CUST_NO NUMBER(4) PRIMARY KEY,    FIRST_NAME VARCHAR2(20) NOT NULL,    LAST_NAME VARCHAR2(20),    ADDRESS VARCHAR2(20),    CITY VARCHAR2(8),    STATE VARCHAR2(20),    PIN NUMBER(6),    B_DATE DATE,    STATUS CHAR(1),    CONSTRAINT chk_status CHECK (STATUS IN ('V','I','A')));\par
 DESC CUSTOMER;\par
 Name                                      Null?    Type\par
 ----------------------------------------- -------- ----------------------------\par
 CUST_NO                                   NOT NULL NUMBER(4)\par
 FIRST_NAME                                NOT NULL VARCHAR2(20)\par
 LAST_NAME                                          VARCHAR2(20)\par
 ADDRESS                                            VARCHAR2(20)\par
 CITY                                               VARCHAR2(8)\par
 STATE                                              VARCHAR2(20)\par
 PIN                                                NUMBER(6)\par
 B_DATE                                             DATE\par
 STATUS                                             CHAR(1)\par
\par
